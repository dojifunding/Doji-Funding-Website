# Doji Funding — Apache Configuration
# Works on InfinityFree and most shared hosting

# ─── Clean URLs (optional — remove .php extensions) ───
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Remove .php extension
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]
    
    # Redirect /challenges to challenges.php etc.
    RewriteRule ^challenges/?$ challenges.php [L]
    RewriteRule ^faq/?$ faq.php [L]
</IfModule>

# ─── Security Headers ───
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header always unset WWW-Authenticate
</IfModule>

# ─── Security ───
# Block access to config files
<FilesMatch "\.(php)$">
    # Only allow entry point files
</FilesMatch>

# Block direct access to .env files
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to .git directory
<IfModule mod_rewrite.c>
    RewriteRule ^\.git - [F,L]
</IfModule>

# Block direct access to includes, config, and database
<IfModule mod_rewrite.c>
    RewriteRule ^config/ - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^database/ - [F,L]
</IfModule>

# ─── Caching ───
# PHP pages: never cache — ensures HTML always has current asset version numbers
<FilesMatch "\.php$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
</FilesMatch>

# LiteSpeed: use full URL including query string as cache key
# so ?v=425 and ?v=426 are distinct entries
<IfModule LiteSpeed>
    RewriteEngine On
    RewriteRule .* - [E=cache-control:no-cache]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    # CSS/JS: short TTL so stale assets expire quickly even if LiteSpeed ignores QS
    ExpiresByType text/css "access plus 1 hour"
    ExpiresByType application/javascript "access plus 1 hour"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # CSS/JS: must-revalidate so clients always check freshness
    <FilesMatch "\.(css|js)$">
        Header append Cache-Control "must-revalidate"
        Header set Vary "Accept-Encoding"
    </FilesMatch>
</IfModule>

# ─── GZIP Compression ───
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# ─── Error pages ───
ErrorDocument 404 /404.php
